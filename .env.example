# =============================================================
# Cá Cảnh Thanh Liêm — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================

# ── Application ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://cacanhthanhliem.com

# ── Supabase ──────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
#
# When left as placeholders the app runs entirely on mock data and
# the custom JWT auth system (admin / TL@Admin2025).
# Replace with real values to activate Supabase Auth + database.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Email (Resend) ────────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Used for contact form notifications (Phase 2)
RESEND_API_KEY=re_your_key_here
ADMIN_EMAIL=info@cacanhthanhliem.com

# ── Admin auth ────────────────────────────────────────────────
# Secret used to sign custom JWT session cookies.
# Generate: openssl rand -base64 48
SESSION_SECRET=change_this_to_a_long_random_string_min_32_chars

# ── Analytics (optional) ─────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
